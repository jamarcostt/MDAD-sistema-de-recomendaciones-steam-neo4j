# =============================================================
#  MatchPlay — .gitignore
# =============================================================

# ── Credenciales y configuración sensible ────────────────────
.env

# ── Neo4j (datos generados por Docker) ───────────────────────
neo4j/data/
neo4j/logs/
neo4j/plugins/
neo4j/init/

# ── CSVs del dataset (demasiado grandes para el repo) ────────
neo4j/import/
*.csv

# ── Spring Boot / Maven ──────────────────────────────────────
api/target/
**/target/
*.jar
*.war
*.class
.mvn/
!.mvn/wrapper/maven-wrapper.jar
!.mvn/wrapper/maven-wrapper.properties

# ── IDEs ─────────────────────────────────────────────────────
.idea/
*.iml
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln

# ── Sistema operativo ─────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini